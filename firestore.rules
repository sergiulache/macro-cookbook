rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // The app is for two people only (D17). UIDs are opaque identifiers, not secrets;
    // they cannot be used to impersonate the accounts.
    function isMember() {
      return request.auth != null && request.auth.uid in [
        'LDl4A6ilzUdGJOsgVLq5CWUg2PA2', // Sergiu
        'B2eHoIgwDqhPDZvu1P8iC3Gpefq2'  // Ana
      ];
    }

    // Per-person data: favorites, notes, custom recipes (D15).
    // Either member can READ (mutually viewable); only the owner can WRITE.
    match /users/{uid} {
      allow read: if isMember();
      allow write: if isMember() && request.auth.uid == uid;
      match /{document=**} {
        allow read: if isMember();
        allow write: if isMember() && request.auth.uid == uid;
      }
    }

    // Joint data: weekly meal plan + shopping list (D15) — both members read+write.
    match /joint/{document=**} {
      allow read, write: if isMember();
    }
  }
}
