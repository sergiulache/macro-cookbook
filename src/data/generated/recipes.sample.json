      {
        "name": "PIZZA BUILD",
        "ingredients": [
          {
            "amount": 1.5,
            "unit": "g",
            "item": "Crisco®"
          },
          {
            "amount": 1,
            "unit": null,
            "item": "dough"
          },
          {
            "amount": 140,
            "unit": "g",
            "item": "fat-free mozzarella cheese, shredded"
          },
          {
            "amount": 168,
            "unit": "g",
            "item": "whole milk low moisture mozzarella cheese, thinly sliced"
          },
          {
            "amount": 280,
            "unit": "g",
            "item": "sausage"
          },
          {
            "amount": 180,
            "unit": "g",
            "item": "6/1 tomato sauce"
          },
          {
            "amount": 5,
            "unit": "g",
            "item": "pecorino romano, grated"
          },
          {
            "amount": 5,
            "unit": "g",
